BoxLayout:
    orientation: 'vertical'
    padding: 10
    spacing: 10

    # Top section: horizontally arranged widgets
    BoxLayout:
        orientation: 'horizontal'
        spacing: 10

        TextInput:
            id: input_number
            text: ''
            multiline: False

        Button:
            text: 'Square'
            on_press: app.handle_square()

        Label:
            id: output_label
            text: ''
            color: 1, 0.75, 0.8, 1  # pink

    # Bottom section: instruction label
    Label:
        text: 'Enter a number and press "Square"'